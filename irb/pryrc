def newweb(str = nil, enable_proxy = nil)
  begin
    require 'mechanize' 
  rescue LoadError
    puts "Mechanize not installed"
  end
  
  $W = Mechanize.new
  if enable_proxy
    $W.set_proxy("localhost",8080)
  end
  
  if str
    unless str.match(/http:\/\//)
      str = "http://" + str
    end
    $W.get(str) 
    puts "[#{$W.page.code},#{$W.page.body.size}] - #{str}"
  end
end

def dif_buf(a,b)
  handles = Array.new
  handles << StringIO.new(a)
  handles << StringIO.new(b)

  while !handles.any?(&:eof)
    bytes = handles.map(&:readbyte)
    if bytes.uniq.size > 1
      @diff = true
      printf "%08x:"+" %02x"*handles.size+"\n", handles[0].pos-1, *bytes
    end 
  end

end

