# Stolen from https://gist.github.com/807492
# Use Array.toy or Hash.toy to get an array or hash to play with

class Object    
    def tap
        yield(self)
        self
    end

    def filetap(filename, mode="a")
        File.open(filename, mode) { |f| f.puts self }
        self
    end

    def vimtap()
        runner = Kernel.method(:system)
        curtime = Time.now.strftime("%Y%m%d")
        @file = "#{curtime}-#{rand(0x1000000).to_s(36)}"
        tf = Tempfile.new(@file)
        tf.open; tf.puts self; tf.rewind
        runner.call("mvim #{tf.path}")
    end
    def hextap()
        runner = Kernel.method(:system)
        curtime = Time.now.strftime("%Y%m%d")
        @file = "#{curtime}-#{rand(0x1000000).to_s(36)}"
        tf = Tempfile.new(@file)
        tf.open; tf.puts self; tf.rewind
        runner.call("open -a \"0xED\" #{tf.path}")
    end
    
    def interesting_methods
     (self.methods - Object.instance_methods).sort
    end
end # object

class Array
  def self.toy(n=10, &block)
    block_given? ? Array.new(n,&block) : Array.new(n) {|i| i+1}
  end
end

class Hash
  def self.toy(n=10)
    Hash[Array.toy(n).zip(Array.toy(n){|c| (96+(c+1)).chr})]
  end
end

class String

  def json_pp
    require 'json'
    JSON.pretty_generate(JSON.parse(self))
  end

  def deflate
    Zlib::Deflate.deflate(self)
  end
  alias :defl :deflate

  def inflate
    Zlib::Inflate.inflate(self)
  end
  alias :infl :inflate

  def chunks(csize)
    (0...self.size).step(csize).map {|x| self[x,csize]}
  end

  def urldec
      CGI.unescape(self)  
  end

  def urlenc
      CGI.escape(self)
  end

  def md5
      Digest::MD5.hexdigest(self)
  end

  def md5d
      Digest::MD5.digest(self)
  end

  def sha1
      Digest::SHA1.hexdigest(self)
  end

  def sha1d
      Digest::SHA1.digest(self)
  end

  def ud64
      self.urldec.tr('_','/').tr('-','+').d64
  end

  def ub64
      self.b64.tr('/','_').tr('+','-').urlenc
  end

  def pbcopy
      IO.popen("pbcopy", "w") {|io| io.write self}
  end

  def pbc
    self.pbcopy
  end

  def ep
    eval(pbpaste)
  end

  def hd
    hexdump
  end

  def feb
    self.force_encoding("ASCII-8BIT")
  end

  def enc
    self.encoding
  end
end

